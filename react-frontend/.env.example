VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Mock de planeación del Ecosistema Cinte en /ecosistema (por defecto habilitado). false = desactivar.
# VITE_ENABLE_ECOSISTEMA_MOCK=false
# El módulo Contratación IA usa solo rutas relativas /api/contratacion/* y el JWT en memoria (cinteAuth).
# No uses VITE_* para API keys del monitor; el WebSocket obtiene ticket vía GET /api/contratacion/ws-token.
