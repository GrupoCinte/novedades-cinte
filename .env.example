# JWT obligatorio (>=32 caracteres). Generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu-secreto-jwt-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5175
# Puerto HTTP del backend (por defecto 3005). Si lo cambias, define en react-frontend/.env la misma URL en VITE_API_PROXY_TARGET.
# PORT=3005
# En desarrollo (NODE_ENV distinto de production) CORS acepta Origin https://*.trycloudflare.com (túnel local).
# Producción: solo orígenes de FRONTEND_URL / CORS_EXTRA_ORIGINS / lista base.
CORS_EXTRA_ORIGINS=
EXPOSE_INTERNAL_ERRORS=false
COGNITO_ENABLED=true
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# --- Microsoft Entra ID (solo portal consultores / radicación en `/`). Cognito sigue siendo el login admin.
# Registrar redirect URI exacta (dev y prod), p. ej. http://localhost:3005/api/auth/entra/callback
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENTRA_REDIRECT_URI=http://localhost:3005/api/auth/entra/callback
# Opcional: host soberano; default login.microsoftonline.com
# ENTRA_AUTHORITY_HOST=login.microsoftonline.com
# TTL sesión JWT consultor en segundos (default 28800 = 8 h)
# CONSULTOR_SESSION_TTL_SEC=28800
# El rol IAM del backend necesita cognito-idp:ListGroups, ListUsersInGroup y AdminGetUser sobre este user pool
# para resolver correos de approvers por grupo (nombres de grupo = claves de rol: admin_ch, team_ch, cac, gp, nomina).
# Grupos de Cognito (cognito:groups) en minúsculas, alineados con src/rbac.js / rolePriority.json.
# Rol comercial (solo cotizador): crear grupo `comercial` y asignar usuarios; el JWT incluirá panel `comercial`.
# Por IP+cuenta (email/username) en el cuerpo; respuestas exitosas no cuentan. Subir solo si aún falta cuota.
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=10
FORGOT_RATE_LIMIT_WINDOW_MIN=60
FORGOT_RATE_LIMIT_MAX=5
# Formulario consultores (POST autenticado /api/enviar-novedad; alias FORM_SUBMIT_*)
PUBLIC_FORM_SUBMIT_RATE_LIMIT_WINDOW_MIN=60
PUBLIC_FORM_SUBMIT_RATE_LIMIT_MAX=10
# Acciones autenticadas: cotizador, gestión, directorio, etc. (clave por usuario o IP)
ADMIN_ACTION_RATE_LIMIT_WINDOW_MIN=60
# Si defines este valor, pisa el default del código (2000 prod / 5000 dev). Opcional.
ADMIN_ACTION_RATE_LIMIT_MAX=2000
PDF_RATE_LIMIT_WINDOW_MIN=10
PDF_RATE_LIMIT_MAX=120
CATALOG_RATE_LIMIT_WINDOW_MIN=5
CATALOG_RATE_LIMIT_MAX=120
EXPORT_MAX_ROWS=5000
# --- Cotizador: catálogo TI se fusiona en `cargos_por_cliente` bajo este nombre de cliente (debe coincidir con `clientes_lideres`; el default en código es CINTE).
# COTIZADOR_CLIENTE_INTERNO_TI=CINTE
S3_ENABLED=false
S3_AUTH_MODE=role
# Región AWS (S3, DynamoDB del módulo Contratación, etc.)
AWS_REGION=us-east-1
S3_BUCKET_NAME=mi-bucket-soportes
S3_SIGNED_URL_TTL_SEC=300
# Opcional en local si usas IAM role en EC2/ECS déjalos vacíos. En dev con S3/Dynamo suele usarse keys (solo backend).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Notificaciones transaccionales (SES + Lambda) ---
# Si está en true, /api/enviar-novedad publica evento asíncrono hacia Lambda.
EMAIL_NOTIFICATIONS_ENABLED=false
# Nombre o ARN de la función Lambda que renderiza y envía correos con SES.
EMAIL_LAMBDA_FUNCTION_NAME=
# (Solo en Lambda) Fallback solo si el evento NO incluye la clave admin.notifyTo (legado). Si el backend envía notifyTo: [] (Cognito sin correos), no se usa este fallback.
# EMAIL_ADMIN_TO=admin@example.com
# EMAIL_ADMIN_TO_CSV=admin1@example.com,admin2@example.com
# (Solo en Lambda) URL HTTPS del logo para los correos. Si vacío: https://novedades.grupocinte.com/assets/logo-cinte-header.png
# EMAIL_LOGO_URL=
# (Solo en Lambda) URL del botón «gestionar» en el correo admin. Si vacío: https://novedades.grupocinte.com/
# EMAIL_GESTION_URL=

# --- Módulo Contratación (monitor n8n / DynamoDB) — alineado con web-contratacion/backend/.env.example ---
# Nombre exacto de la tabla en DynamoDB (la que usa n8n / flujo de contratación).
DYNAMODB_TABLE_NAME=n8n_table_state_users
# Opcional: endpoint solo para DynamoDB Local / LocalStack (vacío = AWS real).
# DYNAMODB_ENDPOINT=http://localhost:4566
# AWS_ENDPOINT_URL_DYNAMODB=http://localhost:4566
# GSI para consulta por email (GET .../users-by-email). Debe existir en la tabla.
DYNAMODB_GSI_NAME=email
DYNAMO_SCAN_QUERY_MAX_ITEMS=5000
CONTRATACION_MAX_ITEMS=5000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=novedades_cinte
DB_USER=cinte_app
# DB_PASSWORD obligatorio (sin fallback hardcodeado)
DB_PASSWORD=tu-password-db-app
CLIENTES_LIDERES_XLSX_PATH=C:\\ruta\\archivo\\Lideres.xlsx
# Credenciales de usuarios y gestión de contraseña se administran exclusivamente en Cognito.

# KPIs opcionales del monitor Contratación (monitor-config)
KPI_HUMAN_PROCESS_TIME_MINUTES=783.5
KPI_HUMAN_HOUR_COST_COP=20000
KPI_AUTO_COST_USD=0.45
KPI_TRM_COP=4200
# Límites dedicados (ventana en minutos; máximos por ventana, clave por usuario tras auth)
CONTRATACION_RATE_LIMIT_WINDOW_MIN=15
CONTRATACION_MONITOR_RATE_LIMIT_MAX=120
CONTRATACION_USERS_BY_EMAIL_RATE_LIMIT_MAX=120
CONTRATACION_ELIMINAR_RATE_LIMIT_MAX=60
CONTRATACION_WS_TOKEN_RATE_LIMIT_MAX=60
# WebSocket: ticket firmado (por defecto mismo secreto que app; en prod puede usarse CONTRATACION_WS_SECRET dedicado)
CONTRATACION_WS_SECRET=
CONTRATACION_WS_TICKET_TTL_SEC=300
# Poller de DynamoDB Streams: habilitar solo si la tabla tiene stream e IAM con GetRecords/DescribeStream
CONTRATACION_STREAM_POLLER_ENABLED=false

# Opcional: `npm run test:api-smoke` (backend debe estar arriba en esta URL)
# TEST_API_URL=http://localhost:3005
# TEST_API_PROBE_MS=3000
# TEST_API_FETCH_MS=10000

# No incluir claves de monitor en VITE_* ni en el bundle del frontend.
