# JWT obligatorio (>=32 caracteres). Generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu-secreto-jwt-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5175
COGNITO_ENABLED=true
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=10
FORGOT_RATE_LIMIT_WINDOW_MIN=60
FORGOT_RATE_LIMIT_MAX=5
FORM_SUBMIT_RATE_LIMIT_WINDOW_MIN=60
FORM_SUBMIT_RATE_LIMIT_MAX=10
CATALOG_RATE_LIMIT_WINDOW_MIN=5
CATALOG_RATE_LIMIT_MAX=120
S3_ENABLED=false
S3_AUTH_MODE=role
AWS_REGION=us-east-1
S3_BUCKET_NAME=mi-bucket-soportes
S3_SIGNED_URL_TTL_SEC=300
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=novedades_cinte
DB_USER=cinte_app
# DB_PASSWORD obligatorio (sin fallback hardcodeado)
DB_PASSWORD=tu-password-db-app
CLIENTES_LIDERES_XLSX_PATH=C:\\ruta\\archivo\\Lideres.xlsx
# Credenciales de usuarios y gestión de contraseña se administran exclusivamente en Cognito.
